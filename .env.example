# Copie para `.env.local` e preencha os valores (nunca commite segredos).
# Se credenciais reais já foram commitadas em `.env.example` ou em outro arquivo no Git,
# rotacione-as no painel de cada provedor (ex.: Mercado Pago → Credenciais de produção/teste).

# Token https://fipe.online (header X-Subscription-Token): script `npm run generate:fipe-seed`, GET /api/fipe/* e export admin GET /api/admin/fipe-catalog-export (JSON+SQL por marca).
# FIPE_SUBSCRIPTION_TOKEN=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Apenas servidor (webhooks MP, RPC admin, etc.)
SUPABASE_SERVICE_ROLE_KEY=

# Bucket de imagens de produto (opcional; padrão: product-images)
# NEXT_PUBLIC_SUPABASE_PRODUCT_IMAGES_BUCKET=product-images

# --- URL pública do site ---
# Usada em Checkout Pro: back_urls, notification_url (webhook).
# Dev: http://localhost:3000 — para o MP alcançar webhooks locais, use um túnel (ngrok, etc.)
# e defina aqui a MESMA origem pública que o MP vai chamar.
# Produção: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=

# --- Modo manutenção (site em construção) ---
# true/1/on/yes = apenas admins acessam normalmente.
NEXT_PUBLIC_MAINTENANCE_MODE=false

# --- Mercado Pago (somente servidor; sem NEXT_PUBLIC_) ---
# Credenciais de produção ou teste (sandbox: token que começa com TEST-...).
# Painel: https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=

# Segredo para validar o cabeçalho `x-signature` em POST /api/webhooks/mercadopago.
# Se vazio, a rota não exige assinatura (útil só em desenvolvimento isolado).
# Configure o mesmo valor no painel do MP (Webhooks / chave de assinatura conforme a doc atual).
MERCADOPAGO_WEBHOOK_SECRET=

# Chave pública (Checkout Bricks / SDK no browser). Formato típico: APP_USR-... ou TEST-... conforme ambiente.
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Credenciais da aplicação no painel (OAuth / integrações que exijam client id/secret).
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=

# --- E-mail transacional (somente servidor; não obrigatório no build) ---
# EMAIL_PROVIDER: console | none | resend
#   - console: log estruturado (dev); não falha checkout/webhook.
#   - none: não envia e-mail.
#   - resend: exige RESEND_API_KEY e EMAIL_FROM com domínio verificado no provedor.
EMAIL_PROVIDER=console

# Obrigatório se EMAIL_PROVIDER=resend (troque o nome da variável se mudar de provedor).
RESEND_API_KEY=

# Remetente no formato "Nome <no-reply@dominioverificado.com>" (SPF/DKIM no DNS do domínio).
EMAIL_FROM=

# --- Melhor Envio (somente servidor) ---
# Fluxo recomendado: OAuth grava access/refresh em `public.melhor_envio_credentials` (Supabase, service_role).
# - Registre o app no painel Melhor Envio; o redirect deve ser EXATAMENTE o valor de MELHOR_ENVIO_REDIRECT_URI.
# - Com admin logado: GET /api/integrations/melhor-envio/authorize → callback troca o code e faz upsert no banco.
# - POST /api/frete/calcular chama ensureMelhorEnvioAccessToken() (só banco + refresh); não usa token estático.
# Doc token OAuth: https://docs.melhorenvio.com.br/reference/solicitacao-do-token
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
# Ex.: https://SEU_DOMINIO/api/integrations/melhor-envio/callback
MELHOR_ENVIO_REDIRECT_URI=

# CEP de origem (8 dígitos, com ou sem máscara). Obrigatório para POST /api/frete/calcular.
MELHOR_ENVIO_CEP_ORIGEM=

# Opcional: exibir só cotações cuja transportadora (nome no Melhor Envio) contém algum destes trechos.
# Separados por vírgula ou ponto e vírgula; comparação sem diferenciar maiúsculas. Ex.: correios,jadlog
# Se vazio ou ausente, todas as opções retornadas pela API entram no checkout.
# MELHOR_ENVIO_SOMENTE_EMPRESAS=jadlog,correios

# --- Retirada na loja (checkout sem frete / sem Correios) ---
# Endereço exibido no checkout e gravado no pedido. CEP só dígitos ou com máscara.
# Se algum campo obrigatório estiver vazio, a opção "Retirar na loja" não aparece.
NEXT_PUBLIC_LOJA_RETIRADA_CEP=
NEXT_PUBLIC_LOJA_RETIRADA_LOGRADOURO=
NEXT_PUBLIC_LOJA_RETIRADA_NUMERO=
# NEXT_PUBLIC_LOJA_RETIRADA_COMPLEMENTO=
NEXT_PUBLIC_LOJA_RETIRADA_BAIRRO=
NEXT_PUBLIC_LOJA_RETIRADA_CIDADE=
NEXT_PUBLIC_LOJA_RETIRADA_UF=

# true = hosts sandbox (*.sandbox.melhorenvio.com.br); false = produção. Afeta authorize, /oauth/token e,
# se MELHOR_ENVIO_API_BASE_URL estiver vazio, a URL de POST /api/v2/me/shipment/calculate.
MELHOR_ENVIO_SANDBOX=true

# Opcional: escopos separados por espaço (padrão no código: shipping-calculate).
# MELHOR_ENVIO_OAUTH_SCOPES=shipping-calculate

# Opcional: sobrescrever URLs (útil se a doc ou o painel divergirem do padrão por ambiente).
# Sem override, o token usa {MELHOR_ENVIO_OAUTH_BASE_URL ou host derivado do sandbox}/oauth/token
# (ex.: https://sandbox.melhorenvio.com.br/oauth/token).
# MELHOR_ENVIO_OAUTH_BASE_URL=
# MELHOR_ENVIO_OAUTH_AUTHORIZE_URL=
# MELHOR_ENVIO_OAUTH_TOKEN_URL=

# Opcional: host base da API REST (cotação). Se vazio, reutiliza a mesma base do OAuth (sandbox ou produção).
# Endpoint usado: POST {base}/api/v2/me/shipment/calculate (Bearer do token OAuth ou legado abaixo).
# MELHOR_ENVIO_API_BASE_URL=

# Recomendado em produção: identificação da integração nas requisições (nome + e-mail de contato técnico).
# MELHOR_ENVIO_USER_AGENT="MinhaLoja/1.0 (contato@exemplo.com)"

# DEPRECATED — token Bearer único em env. Não use em produção para a loja: o fluxo principal é OAuth + Supabase.
# Ainda lido por getMelhorEnvioConfigFromEnv() quando quoteShipment/createOrder são chamados sem `{ token }` explícito
# (código legado ou testes). Deixe vazio se você usa apenas /api/frete/calcular + authorize/callback.
MELHOR_ENVIO_TOKEN=

# --- Consulta de placa (somente servidor) ---
# Token da API de consulta de placa usada na home.
MINHAS_PLACAS_TOKEN=
